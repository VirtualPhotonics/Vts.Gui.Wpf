<UserControl x:Class="Vts.Gui.Wpf.View.Controls.ListBoxOptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:designViewModels="clr-namespace:Vts.Gui.Wpf.DesignViewModels"
             d:DataContext="{d:DesignInstance Type=designViewModels:ForwardSolverOptionViewModel, IsDesignTimeCreatable=True}">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock
            x:Name="Header" Text="{Binding GroupName}"
            Visibility="{Binding ShowTitle, Converter={StaticResource MyBooleanToVisibilityConverter}}"
            FontSize="16"
            TextDecorations="Underline"
            Margin="0,0,10,0" />
        <ListBox
            ItemsSource="{Binding Options.Values}"
            SelectedValue="{Binding SelectedValue, Mode=TwoWay}"
            SelectedValuePath="Value"
            DisplayMemberPath="DisplayName"
            Height="25" />
    </StackPanel>
</UserControl>