<UserControl x:Class="Vts.Gui.Wpf.View.Controls.ComboBoxOptionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:designViewModels="clr-namespace:Vts.Gui.Wpf.DesignViewModels"
             d:DataContext="{d:DesignInstance Type=designViewModels:ForwardSolverOptionViewModel, IsDesignTimeCreatable=True}">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
        <TextBlock
            x:Name="Header" Text="{Binding GroupName}"
            Visibility="{Binding ShowTitle, Converter={StaticResource MyBooleanToVisibilityConverter}}"
            FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,0,2,0" />
        <ComboBox
            ItemsSource="{Binding Options.Values}"
            SelectedValue="{Binding SelectedValue, Mode=TwoWay}"
            DisplayMemberPath="DisplayName"
            SelectedValuePath="Value"
            Height="22"
            FontSize="11" />
    </StackPanel>
</UserControl>